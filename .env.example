# ══════════════════════════════════════════════════════════════════
# PeakEstimator — Environment Variables Reference
# Copy to .env.local and fill in real values. Never commit .env.local
# ══════════════════════════════════════════════════════════════════

# ─── Frontend (Vite) ──────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Supabase Edge Function Secrets ──────────────────────────────
# Set these in: Supabase Dashboard → Project Settings → Edge Functions → Secrets
# (Do NOT put them in .env.local — they are server-side only)
#
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_URL=https://your-project.supabase.co
# SITE_URL=https://lmtrx.us
#
# Stripe (required for stripe-checkout, stripe-webhook edge functions)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_ENTERPRISE_PRICE_ID=price_...
#
# Email (required for email-followup, notify-contractor edge functions)
# RESEND_API_KEY=re_...
# FROM_EMAIL=noreply@peakestimator.com
#
# AI (required for ai-estimator, ai-transcribe edge functions)
# OPENAI_API_KEY=sk-...
#
# Auth Hook Secret (required for track-login edge function)
# TRACK_LOGIN_HOOK_SECRET=generate-a-random-secret-here
#
# PDF Generation (required for generate-pdf)
# PDF_SERVICE_URL=https://...  (or leave blank to use browser-based generation)

